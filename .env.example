# Copy this file to .env and fill in the keys you have.
# The system works in MOCK mode with no keys at all (great for demos/portfolio recording),
# and automatically switches a provider to "live" mode as soon as its key is present.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local Ollama server (only used if OLLAMA_ENABLED=true and the server is reachable)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# If true, every provider call is simulated (deterministic fake latency/cost/text).
# Useful for load-testing the routing/verification/dashboard pipeline without spending money.
FORCE_MOCK_MODE=true

# SQLite database path
DB_PATH=./data/autopilot.db

# Verifier
VERIFIER_ENABLED=true
AUTO_ESCALATE=true
ESCALATION_SIMILARITY_THRESHOLD=0.55
